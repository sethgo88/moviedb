{
  "permissions": {
    "allow": [
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm:*)",
      "Bash(git push:*)",
      "mcp__github__issue_write"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); if [[ \"$FILE\" == *.ts || \"$FILE\" == *.tsx ]]; then pnpm biome check --write \"$FILE\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm typecheck || exit 2"
          }
        ]
      }
    ]
  }
}
