{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"sql:default",
		"sql:allow-execute",
		"dialog:allow-open",
		"fs:allow-read-file",
		"http:default",
		{
			"identifier": "http:allow-fetch",
			"allow": [
				{ "url": "http://*:*/**" },
				{ "url": "https://*:*/**" }
			]
		}
	]
}
